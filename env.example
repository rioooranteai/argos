# ── LLM Provider ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ─────────────────────────────────────────────────────
# Path SQLite di dalam container (sesuaikan dengan volume di docker-compose)
DATABASE_URL=./competitor_data.db

# ── ChromaDB ─────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── App Config ───────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
